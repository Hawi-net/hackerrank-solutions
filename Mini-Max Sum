#
# Complete the 'miniMaxSum' function below.
#
# The function accepts INTEGER_ARRAY arr as parameter.
#

def miniMaxSum(arr):
    # Write your code here
    sum =0
    n =len(arr)
    arr.sort()
    for i in range(n):
        sum =sum +arr[i]
    min =sum -arr[n-1]
    max =sum -arr[0]
    print(min,max)
    
        
        
        
    

if __name__ == '__main__':

    arr = list(map(int, input().rstrip().split()))

